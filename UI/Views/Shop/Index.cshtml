@using Core.Concretes.Dtos
@model CartDto

@{
    ViewData["Title"] = "Sepetim";
    decimal genelToplam = Model.Items.Sum(x => x.DiscountedPrice * x.Quantity);
    decimal araToplam = Model.Items.Sum(x => x.Price * x.Quantity);
    decimal toplamIndirim = araToplam - genelToplam;
}

<div class="container my-5">
    <div class="d-flex align-items-center mb-4">
        <i class="fa-solid fa-cart-shopping fa-2x text-primary me-3"></i>
        <h2 class="mb-0 fw-bold">Alışveriş Sepetim</h2>
    </div>

    @if (Model.Items != null && Model.Items.Any())
    {
        <div class="row g-4">
            <div class="col-lg-8">
                <div class="card shadow-sm border-0">
                    <div class="table-responsive">
                        <table class="table align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th class="ps-4 py-3">Ürün Detayı</th>
                                    <th>Birim Fiyat</th>
                                    <th style="width: 130px;">Adet</th>
                                    <th>Toplam</th>
                                    <th class="text-end pe-4">İşlem</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.Items)
                                {
                                    <tr>
                                        <td class="ps-4 py-3">
                                            <div class="d-flex align-items-center">
                                                @if (!string.IsNullOrEmpty(item.ProductImage))
                                                {
                                                    <img src="@item.ProductImage" alt="@item.ProductName" class="rounded border" style="width: 70px; height: 70px; object-fit: cover;">
                                                }
                                                else
                                                {
                                                    <div class="rounded border bg-light d-flex align-items-center justify-content-center text-muted" style="width: 70px; height: 70px;">
                                                        <i class="fa-solid fa-image fa-xl"></i>
                                                    </div>
                                                }
                                                <div class="ms-3">
                                                    <h6 class="mb-1 fw-bold">@item.ProductName</h6>
                                                    <small class="text-muted text-uppercase">Ürün Kodu: #@item.ProductId</small>
                                                </div>
                                            </div>
                                        </td>
                                        <td>
                                            @if (item.DiscountedPrice < item.Price)
                                            {
                                                <div class="text-muted small text-decoration-line-through">@item.Price.ToString("C2")</div>
                                                <div class="fw-bold text-danger">@item.DiscountedPrice.ToString("C2")</div>
                                            }
                                            else
                                            {
                                                <div class="fw-bold">@item.Price.ToString("C2")</div>
                                            }
                                        </td>
                                        <td>
                                            <div class="input-group input-group-sm border rounded">
                                                <a class="btn btn-link text-dark px-2 border-0"
                                                   asp-action="addToCart"
                                                   asp-controller="shop"
                                                   asp-route-pid="@item.ProductId"
                                                   asp-route-quantity="-1">
                                                    <i class="fa-solid fa-minus fa-xs"></i>
                                                </a>
                                                <input type="text" class="form-control border-0 text-center bg-transparent fw-bold" value="@item.Quantity" readonly>
                                                <a class="btn btn-link text-dark px-2 border-0"
                                                   asp-action="addToCart"
                                                   asp-controller="shop"
                                                   asp-route-pid="@item.ProductId"
                                                   asp-route-quantity="1">
                                                    <i class="fa-solid fa-plus fa-xs"></i>
                                                </a>
                                            </div>
                                        </td>
                                        <td>
                                            <span class="fw-bold text-dark">@((item.DiscountedPrice * item.Quantity).ToString("C2"))</span>
                                        </td>
                                        <td class="text-end pe-4">
                                            <a class="btn btn-outline-secondary btn-sm border-0 rounded-circle p-2"
                                               asp-action="removeFromCart"
                                               asp-controller="shop"
                                               asp-route-pid="@item.ProductId">
                                                <i class="fa-solid fa-trash-can text-danger"></i>
                                            </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>

                <div class="mt-4">
                    <a href="/" class="btn btn-outline-dark rounded-pill px-4 shadow-sm">
                        <i class="fa-solid fa-arrow-left me-2"></i>Alışverişe Devam Et
                    </a>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="card shadow border-0 p-3">
                    <h5 class="fw-bold mb-4">Sipariş Özeti</h5>

                    <div class="d-flex justify-content-between mb-3 text-secondary">
                        <span>Ara Toplam</span>
                        <span>@araToplam.ToString("C2")</span>
                    </div>

                    @if (toplamIndirim > 0)
                    {
                        <div class="d-flex justify-content-between mb-3 text-success">
                            <span><i class="fa-solid fa-tags me-1"></i> Toplam İndirim</span>
                            <span class="fw-bold">-@toplamIndirim.ToString("C2")</span>
                        </div>
                    }

                    <div class="d-flex justify-content-between mb-3">
                        <span>Kargo Ücreti</span>
                        <span class="text-success fw-bold">Ücretsiz</span>
                    </div>

                    <hr class="my-4">

                    <div class="d-flex justify-content-between mb-4">
                        <span class="h5 fw-bold">Ödenecek Tutar</span>
                        <span class="h5 fw-bold text-primary">@genelToplam.ToString("C2")</span>
                    </div>

                    <div class="d-grid">
                        <button class="btn btn-primary btn-lg rounded-3 py-3 shadow">
                            <i class="fa-solid fa-credit-card me-2"></i>Ödemeye Geç
                        </button>
                    </div>

                    <div class="mt-4 text-center">
                        <div class="small text-muted mb-2">Güvenli Ödeme Seçenekleri</div>
                        <div class="d-flex justify-content-center gap-3 text-muted">
                            <i class="fa-brands fa-cc-visa fa-2x"></i>
                            <i class="fa-brands fa-cc-mastercard fa-2x"></i>
                            <i class="fa-solid fa-shield-halved fa-2x text-success"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="card border-0 shadow-sm py-5 text-center">
            <div class="card-body">
                <div class="mb-4 text-muted opacity-25">
                    <i class="fa-solid fa-cart-arrow-down fa-6x"></i>
                </div>
                <h3 class="fw-bold">Sepetiniz Boş!</h3>
                <p class="text-muted mb-4">Görünüşe göre henüz bir seçim yapmadınız.</p>
                <a href="/" class="btn btn-primary btn-lg rounded-pill px-5">
                    Hemen Alışverişe Başla
                </a>
            </div>
        </div>
    }
}</div>