@model IEnumerable<ProductListItemDto>
@{
    ViewData["Title"] = "Home Page";
}

<div class="container-fluid py-5">
    <div class="row mb-4">
        <div class="col-12">
            <h1 class="display-5 fw-bold">
                <i class="fas fa-shopping-bag me-3"></i>Ürünler
            </h1>
            <p class="text-muted">Geniş ürün yelpazesinden seçim yapın</p>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="row">
            <div class="col-12">
                <div class="alert alert-info text-center py-5" role="alert">
                    <i class="fas fa-info-circle me-2"></i>
                    <span>Hiç ürün bulunamadı</span>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var product in Model)
            {
                <div class="col-12 col-sm-6 col-lg-4 col-xl-3">
                    <div class="card h-100 shadow-sm border-0 overflow-hidden transition-all" style="cursor: pointer; transition: all 0.3s ease;">
                        <!-- Resim Alanı -->
                        <div class="position-relative overflow-hidden bg-light" style="height: 250px;">
                            @if (!string.IsNullOrEmpty(product.CoverImageUrl))
                            {
                                <img src="@product.CoverImageUrl"
                                     alt="@product.Name"
                                     class="img-fluid w-100 h-100"
                                     style="object-fit: cover;" />
                            }
                            else
                            {
                                <div class="d-flex align-items-center justify-content-center h-100 bg-secondary bg-opacity-10">
                                    <i class="fas fa-image text-secondary" style="font-size: 3rem;"></i>
                                </div>
                            }

                            <!-- Kategori Badge -->
                            <div class="position-absolute top-0 start-0 m-2">
                                <span class="badge bg-primary">@product.CategoryName</span>
                            </div>

                            <!-- İndirim Badge -->
                            @if (product.DiscountRate > 0)
                            {
                                <div class="position-absolute top-0 end-0 m-2">
                                    <span class="badge bg-danger">
                                        <i class="fas fa-tag me-1"></i>%@product.DiscountRate İndirim
                                    </span>
                                </div>
                            }
                        </div>

                        <div class="card-body d-flex flex-column">
                            <!-- Marka -->
                            <small class="text-muted d-block mb-2">
                                <i class="fas fa-building me-1"></i>@product.BrandName
                            </small>

                            <!-- Ürün Adı -->
                            <h5 class="card-title fw-semibold text-truncate" title="@product.Name">
                                @product.Name
                            </h5>

                            <!-- Alt Kategori -->
                            <small class="text-muted d-block mb-3">
                                @product.SubCategoryName
                            </small>

                            <!-- Fiyat -->
                            <div class="mb-3">
                                @if (product.DiscountRate > 0)
                                {
                                    <div class="d-flex align-items-center gap-2">
                                        <span class="text-decoration-line-through text-muted">
                                            @product.Price.ToString("C")
                                        </span>
                                        <span class="h5 mb-0 fw-bold text-danger">
                                            @product.DiscountedPrice.ToString("C")
                                        </span>
                                    </div>
                                }
                                else
                                {
                                    <span class="h5 mb-0 fw-bold text-success">
                                        @product.Price.ToString("C")
                                    </span>
                                }
                            </div>

                            <!-- Rating -->
                            <div class="d-flex align-items-center gap-2 mb-3 mt-auto">
                                <div class="d-flex gap-1">
                                    @for (int i = 0; i < 5; i++)
                                    {
                                        @if (i < product.Rating)
                                        {
                                            <i class="fas fa-star text-warning"></i>
                                        }
                                        else
                                        {
                                            <i class="far fa-star text-warning"></i>
                                        }
                                    }
                                </div>
                                <small class="text-muted">
                                    (@product.ReviewCount yorum)
                                </small>
                            </div>

                            <a asp-action="addToCart"
                               asp-controller="shop"
                               asp-route-pid="@product.Id"
                               class="btn btn-outline-dark btn-lg w-100">
                                🛒 Sepete Ekle
                            </a>
                        </div>

                        <!-- Hover Efekti için CSS -->
                        <style>
                            .card:hover {
                                transform: translateY(-5px);
                                box-shadow: 0 0.75rem 1.5rem rgba(0, 0, 0, 0.15) !important;
                            }

                                .card:hover img {
                                    transform: scale(1.05);
                                    transition: transform 0.3s ease;
                                }
                        </style>
                    </div>
                </div>
            }
        </div>
    }
</div>
