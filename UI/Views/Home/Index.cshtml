@using Core.Concretes.Dtos
@model IEnumerable<ProductListItemDto>
@{
    ViewData["Title"] = "Ürünler";
}

<style>
    .product-card {
        transition: transform 0.25s ease, box-shadow 0.25s ease;
        border-radius: 16px;
        overflow: hidden;
    }

        .product-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 1rem 2rem rgba(0,0,0,0.12) !important;
        }

            .product-card:hover .product-img {
                transform: scale(1.05);
            }

    .product-img {
        transition: transform 0.35s ease;
        object-fit: cover;
        width: 100%;
        height: 100%;
    }

    .img-wrapper {
        height: 240px;
        overflow: hidden;
        background: #f5f5f5;
    }

    .btn-cart {
        background: #111;
        color: #fff;
        border: none;
        border-radius: 10px;
        font-weight: 600;
        letter-spacing: 0.3px;
        transition: background 0.2s;
    }

        .btn-cart:hover {
            background: #333;
            color: #fff;
        }

    .stars i {
        font-size: 0.75rem;
    }

    .badge-cat {
        font-size: 0.72rem;
        border-radius: 6px;
    }

    .price-original {
        font-size: 0.85rem;
        color: #aaa;
        text-decoration: line-through;
    }

    .price-discounted {
        font-size: 1.15rem;
        font-weight: 700;
        color: #e53935;
    }

    .price-normal {
        font-size: 1.15rem;
        font-weight: 700;
        color: #1a73e8;
    }
</style>

<div class="container-fluid py-4 px-4">
    <div class="d-flex align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-0"><i class="fa-solid fa-bag-shopping me-2 text-primary"></i>Ürünler</h2>
            <p class="text-muted small mb-0">Geniş ürün yelpazesinden seçim yapın</p>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show d-flex align-items-center gap-2 mb-3" role="alert">
            <i class="fa-solid fa-circle-check"></i>
            <span>@TempData["Success"]</span>
            <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show d-flex align-items-center gap-2 mb-3" role="alert">
            <i class="fa-solid fa-circle-exclamation"></i>
            <span>@TempData["Error"]</span>
            <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (!Model.Any())
    {
        <div class="text-center py-5 text-muted">
            <i class="fa-solid fa-box-open fa-4x mb-3 opacity-25"></i>
            <h5>Hiç ürün bulunamadı</h5>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var product in Model)
            {
                <div class="col-12 col-sm-6 col-lg-4 col-xl-3">
                    <div class="card h-100 border-0 shadow-sm product-card">
                        <div class="img-wrapper position-relative">
                            @if (!string.IsNullOrEmpty(product.CoverImageUrl))
                            {
                                <img src="@product.CoverImageUrl" alt="@product.Name" class="product-img" />
                            }
                            else
                            {
                                <div class="d-flex align-items-center justify-content-center h-100 text-muted">
                                    <i class="fa-regular fa-image fa-3x opacity-25"></i>
                                </div>
                            }

                            <div class="position-absolute top-0 start-0 m-2">
                                <span class="badge bg-primary badge-cat">@product.CategoryName</span>
                            </div>

                            @if (product.DiscountRate > 0)
                            {
                                <div class="position-absolute top-0 end-0 m-2">
                                    <span class="badge bg-danger badge-cat">%@product.DiscountRate İndirim</span>
                                </div>
                            }
                        </div>

                        <div class="card-body d-flex flex-column px-3 pt-3 pb-3">
                            <small class="text-muted mb-1" style="font-size:0.78rem;">
                                <i class="fa-regular fa-building me-1"></i>@product.BrandName
                                &nbsp;·&nbsp;@product.SubCategoryName
                            </small>

                            <h6 class="fw-semibold mb-2 text-truncate" title="@product.Name">@product.Name</h6>

                            <div class="mb-2">
                                @if (product.DiscountRate > 0)
                                {
                                    <span class="price-original">@product.Price.ToString("C")</span>
                                    <span class="price-discounted ms-2">@product.DiscountedPrice.ToString("C")</span>
                                }
                                else
                                {
                                    <span class="price-normal">@product.Price.ToString("C")</span>
                                }
                            </div>

                            <div class="stars d-flex align-items-center gap-1 mb-3 mt-auto">
                                @for (int i = 0; i < 5; i++)
                                {
                                    <i class="@(i < product.Rating ? "fa-solid" : "fa-regular") fa-star text-warning"></i>
                                }
                                <small class="text-muted ms-1">(@product.ReviewCount)</small>
                            </div>

                            <a asp-action="addToCart"
                               asp-controller="shop"
                               asp-route-pid="@product.Id"
                               asp-route-returnUrl="/"
                               class="btn btn-cart w-100 py-2">
                                <i class="fa-solid fa-cart-plus me-2"></i>Sepete Ekle
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
