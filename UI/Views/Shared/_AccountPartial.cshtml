@using Core.Abstracts.IServices
@using Core.Concretes.Entities
@using Microsoft.AspNetCore.Identity
@inject IShopService ShopService
@inject UserManager<Customer> UserManager
<nav class="nav align-items-center">
    @if (User.Identity.IsAuthenticated != null && User.Identity.IsAuthenticated)
    {
        var customer = await UserManager.GetUserAsync(User);
        var cart = await ShopService.GetCartAsync(customer.Id);
        int itemCount = cart?.Items?.Count() ?? 0;

        <a class="nav-link" asp-action="index" asp-controller="accounts">
            <i class="fa-solid fa-user me-1"></i>Profilim
        </a>

        <a class="nav-link position-relative me-3" asp-action="index" asp-controller="shop">
            <i class="fa-solid fa-cart-shopping me-1"></i>Sepetim
            @if (itemCount > 0)
            {
                <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="font-size:0.65rem;">
                    @itemCount
                </span>
            }
        </a>

        <form asp-action="logout" asp-controller="accounts" method="post">
            <button type="submit" class="nav-link btn btn-link p-0">
                <i class="fa-solid fa-right-from-bracket me-1"></i>Çıkış
            </button>
        </form>
    }
    else
    {
        <a class="nav-link" asp-action="login" asp-controller="accounts">
            <i class="fa-solid fa-right-to-bracket me-1"></i>Giriş Yap
        </a>
        <a class="nav-link" asp-action="register" asp-controller="accounts">
            <i class="fa-solid fa-user-plus me-1"></i>Kayıt Ol
        </a>
    }
</nav>
